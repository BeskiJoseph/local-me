rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // DEFAULT: Block all direct client access.
    // All data operations go through the Node.js backend (Admin SDK).
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // EXCEPTION: Event Chat Messages (Real-time requirement)
    //
    // Chat requires Firestore snapshots() for instant delivery.
    // These rules are scoped ONLY to the messages subcollection.
    // ──────────────────────────────────────────────
    match /posts/{postId}/messages/{messageId} {
      // Read: Any authenticated user can read messages
      // (Event membership check is enforced at UI level + backend join logic)
      allow read: if request.auth != null;

      // Write: Authenticated users can only create messages (not update/delete)
      // with strict field validation to prevent injection
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['senderId', 'text', 'timestamp'])
        && request.resource.data.senderId == request.auth.uid  // Can only send as yourself
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 2000;          // Max message length

      // No update or delete from client — only backend/admin can moderate
      allow update, delete: if false;
    }
  }
}
