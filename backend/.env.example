# Server
PORT=4000
NODE_ENV=development

# Firebase Admin
FIREBASE_PROJECT_ID=testpro-73a93
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@testpro-73a93.iam.gserviceaccount.com

# JWT Security
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_SECRET

# Cloudflare R2
R2_ACCOUNT_ID=REPLACE_WITH_R2_ACCOUNT_ID
R2_ACCESS_KEY_ID=REPLACE_WITH_R2_ACCESS_KEY
R2_SECRET_ACCESS_KEY=REPLACE_WITH_R2_SECRET_KEY
R2_BUCKET_NAME=localme
R2_PUBLIC_BASE_URL=https://media-proxy.example.workers.dev

# Amazon SES (SMTP Driver)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=REPLACE_WITH_SES_SMTP_USER
SMTP_PASS=REPLACE_WITH_SES_SMTP_PASS
SMTP_FROM_EMAIL=verified-sender@yourdomain.com

# Logging
LOG_LEVEL=info
